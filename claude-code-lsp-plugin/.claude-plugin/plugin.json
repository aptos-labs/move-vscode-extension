{
    "name": "move-lsp",
    "description": "Aptos Labs' Move language server integration",
    "version": "1.0.0",
    "author": {
        "name": "Maksim Kurnikov"
    },
    "lspServers": {
        "move": {
            "command": "aptos-language-server",
            "args": [
                "lsp-server"
            ],
            "extensionToLanguage": {
                ".move": "move"
            },
            "transport": "stdio",
            "initializationOptions": {},
            "settings": {},
            "maxRestarts": 3
        }
    }
}
